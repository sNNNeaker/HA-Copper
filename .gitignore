# --- Secrets & captured data (NEVER commit — see scrub notes) ---
# proxy captures (contain tokens + PII)
*.har
# environment files with credentials
.env
.env.*
# keys / certificates
*.pem
*.key
secrets.*
tokens.*

# --- Python build artifacts (regenerated automatically) ---
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/
.eggs/

# --- Testing / tooling caches ---
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/
.tox/

# --- Virtual environments ---
.venv/
venv/
env/

# --- Editor / OS cruft ---
.vscode/
.idea/
.DS_Store
Thumbs.db
